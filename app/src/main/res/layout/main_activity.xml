<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/colorBackground"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:paddingHorizontal="15dp"
    android:paddingTop="40dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingBottom="10dp">

        <TextView
            android:id="@+id/secret_key_label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="BASE64 SECRET KEY"
            android:textAppearance="@style/TextAppearance.AppCompat.Display1"
            android:textColor="@color/material_dynamic_primary70"
            android:textFontWeight="500" />

        <EditText
            android:id="@+id/secret_key_text_entry"
            android:layout_width="match_parent"
            android:layout_height="68dp"
            android:ems="10"
            android:inputType="text|textVisiblePassword|textNoSuggestions" />

        <Button
            android:id="@+id/secret_key_save_button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/material_dynamic_neutral40"
            android:text="save" />

    </LinearLayout>

    <View
        android:id="@+id/divider"
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:background="?android:attr/listDivider" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingTop="10dp">

        <TextView
            android:id="@+id/computer_hostname_label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="COMPUTER HOSTNAME"
            android:textAppearance="@style/TextAppearance.AppCompat.Display1"
            android:textColor="@color/material_dynamic_primary70"
            android:textFontWeight="500" />

        <EditText
            android:id="@+id/computer_hostname_text_entry"
            android:layout_width="match_parent"
            android:layout_height="68dp"
            android:ems="10"
            android:inputType="text|textNoSuggestions" />

        <Button
            android:id="@+id/computer_hostname_save_button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/material_dynamic_neutral40"
            android:text="save" />

    </LinearLayout>

</LinearLayout>